{
    // === ИНТЕРФЕЙС (Linux/Windows) ===

    // === Рабочая область и интерфейс ===
    "workbench.activityBar.location": "hidden",          // Скрывает левую боковую панель с иконками (Projects/Explorer/Git)
    "workbench.sideBar.location": "right",               // Переносит боковую панель (Explorer/Git) справа — удобно для левши

    // === Вкладки и заголовки ===
    "workbench.editor.showTabs": "single",               // Показывает только активную вкладку, остальные — в dropdown
    "workbench.editor.showIcons": false,                 // Убирает иконки файлов с вкладок (чище вид)
    "workbench.editor.labelFormat": "medium",            // Формат имени файла: имя + папка (не слишком длинно)
    "breadcrumbs.enabled": false,                        // Отключает хлебные крошки (путь наверху редактора)

    // === Автообновления (ВСЁ ОТКЛЮЧЕНО) ===
    "extensions.autoCheckUpdates": true,                // Не проверять обновления расширений автоматически
    "extensions.autoUpdate": true,                      // Не обновлять расширения автоматически
    "update.showReleaseNotes": false,                    // Не показывать заметки к релизам
    "update.mode": "default",                              // ПОЛНОЕ отключение обновлений VS Code

    // === Редактор ===
    "editor.minimap.enabled": false,                     // Мини-карта справа (отключает — больше места для кода)
    "workbench.colorTheme": "GitHub Dark Default", // Тёмная тема Monokai (классика для Python)
    "workbench.iconTheme": "material-icon-theme",
    "material-icon-theme.hidesExplorerArrows": true,
    "workbench.tree.enableStickyScroll": false,
    "workbench.tree.renderIndentGuides": "none",
    "workbench.tree.indent": 16,

    // === ТЕРМИНАЛ (везде) ===
    "terminal.integrated.cursorStyle": "line",           // Курсор в терминале — вертикальная черта
    "terminal.integrated.cursorBlinking": true,          // Курсор в терминале мигает

    // === Поиск и навигация ===
    "editor.find.seedSearchStringFromSelection": "selection", // Выделил текст → Ctrl+F ищет именно его
    "files.autoSave": "afterDelay",                      // Автосохранение через 1 сек бездействия
    "explorer.autoReveal": false,                        // Не подсвечивать файл в Explorer при клике на него
    "explorer.compactFolders": false,                    // Папки показывать полностью (не сокращать имена)
    
    // === Интерфейс ===
    "window.commandCenter": false,                       // Скрыть панель команд вверху (File/Edit/View)
    "workbench.statusBar.visible": false,
    "workbench.startupEditor": "none",                   // При запуске — пустое окно (не стартовые файлы)
    "window.zoomLevel": 0,                               // Масштаб окна 100% (0 = стандарт)
    "editor.fontSize": 15,                               // Размер шрифта
    "git.confirmSync": false,

    // === MARKDOWN / README.md ===
    "[markdown]": {
        "editor.wordWrap": "on",
        "editor.quickSuggestions": {
            "comments": "on",
            "strings": "on",
            "other": "on"
        },
        "editor.formatOnSave": true
    },
    "markdown.preview.fontSize": 14,
    "markdown.preview.lineHeight": 1.6,
    "markdown.preview.markEditorSelectionInfo": true,
    
    "git.enableSmartCommit": true,
    "explorer.confirmDelete": false,
    
  
}
